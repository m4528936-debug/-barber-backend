# ── SERVER ──
PORT=3000
NODE_ENV=development

# ── JWT ──
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=30d

# ── DATABASE ──
DB_PATH=./data/barber.db

# ── ADMIN ──
ADMIN_PIN=1234

# ── OTP (SMS) ──
# اگه SMS_API_KEY رو خالی بذاری، کد فقط توی کنسول سرور چاپ می‌شه (حالت توسعه)
SMS_PROVIDER=kavenegar
SMS_API_KEY=
SMS_SENDER=
# فقط برای ملی‌پیامک لازمه:
SMS_USERNAME=
SMS_PASSWORD=

# ── PAYMENT (ZarinPal) ──
# اگه ZARINPAL_MERCHANT رو خالی بذاری، حالت mock فعال می‌شه (بدون نیاز به مرچنت واقعی)
ZARINPAL_MERCHANT=
ZARINPAL_SANDBOX=1
ZARINPAL_CALLBACK_URL=http://localhost:3000/api/payments/verify

# ── UPLOAD ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ── SUPABASE (production) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key
